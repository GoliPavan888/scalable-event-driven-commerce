# Write database
WRITE_DB_NAME=write_db
WRITE_DB_USER=user
WRITE_DB_PASSWORD=password
WRITE_DB_PORT=5432
DATABASE_URL=postgresql://user:password@db:5432/write_db

# Read database
READ_DB_NAME=read_db
READ_DB_USER=user
READ_DB_PASSWORD=password
READ_DB_PORT=5433
READ_DATABASE_URL=postgresql://user:password@read-db:5432/read_db

# Message broker
BROKER_URL=amqp://guest:guest@broker:5672/
BROKER_PORT=5672
BROKER_MANAGEMENT_PORT=15672
BROKER_EXCHANGE=commerce.events
QUEUE_NAME=analytics-projection-queue
PREFETCH_COUNT=20

# Service ports
COMMAND_SERVICE_PORT=8080
QUERY_SERVICE_PORT=8081

# Publisher settings
OUTBOX_POLL_INTERVAL_MS=2000
